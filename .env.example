# Inference
DEVICE=cuda
REF_AUDIO_MAX_SEC=8
F5_TIMEOUT_SEC=600
F5_NFE_STEP=32
F5_SPEED=1.0
F5_CROSS_FADE=0.15
F5_FORCE_FP32=true
HINDI_BASE_VOICE=hi-IN-MadhurNeural
URDU_BASE_VOICE=ur-PK-AsadNeural

# Podcast
DEFAULT_PAUSE_MS=500
CROSSFADE_MS=120

# Training pipeline
CHUNK_SECONDS=10
NORMALIZE_DBFS=-20.0
SILENCE_THRESH_DB=-40.0
MIN_SILENCE_LEN_MS=500
KEEP_SILENCE_MS=150
NOISE_REDUCTION_AMT=0.75

# Paths
RAW_AUDIO_DIR=./raw_audio

# Server
SERVER_NAME=127.0.0.1
SERVER_PORT=7860
SHARE=false